# Copiar como .env y completar los valores
# IMPORTANTE: este archivo SÍ va a GitHub. El .env real NUNCA.

# PostgreSQL — local
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/portfolio_ar

# JWT secret — generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-algo-secreto-y-largo

# CORS — URLs del frontend permitidas (coma-separated)
# Local:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Produccion (reemplazar con URL de Vercel):
# ALLOWED_ORIGINS=https://tu-app.vercel.app
